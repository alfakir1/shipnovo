# Root .gitignore for ShipNovo

# Dependencies
node_modules/
vendor/

# Environment files
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
.fleet/
.nova/
.zed/

# PHP/Laravel specific (backend)
/backend/public/build/
/backend/public/hot/
/backend/public/storage/
/backend/storage/*.key
/backend/storage/pail/
/backend/auth.json
/backend/.phpunit.result.cache
/backend/.phpunit.cache
/backend/Homestead.json
/backend/Homestead.yaml

# React/Next.js/Vite specific (frontend)
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/coverage/
/frontend/.pnp
/frontend/.pnp.*
/frontend/.yarn/*
!/frontend/.yarn/patches
!/frontend/.yarn/plugins
!/frontend/.yarn/releases
!/frontend/.yarn/versions
/frontend/*.tsbuildinfo
/frontend/next-env.d.ts

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Other
/api/vendor/
/api/node_modules/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
